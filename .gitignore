# ─────────────────────────────────────────────────────────────
# Kaleidoscope monorepo — .gitignore
# Rule of thumb: commit SOURCE and project.yml; never commit build
# caches, generated Xcode projects, live data, or secrets.
# ─────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit ──────────────────────────────────
# Real secrets live outside git. Templates (*.example.*) ARE committed.
**/Secrets.swift
ios/Sources/Backend/Secrets.swift
**/Secrets.plist
*.p8
*.pem
*.mobileprovision
*.p12
*.cer
id_rsa*
.env
.env.*
!.env.example
.api_keys
**/*secret*.json
**/*credentials*.json

# ── Generated Xcode projects (regenerated by `xcodegen generate`) ──
*.xcodeproj/
*.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata

# ── Build outputs / caches (regenerable; never commit) ──────
build/
Build/
DerivedData/
.build/
.build-*/
.swiftpm/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.modulecache
ModuleCache.noindex/
SourcePackages/
.derivedData/
.worktrees/
*.ipa
*.app.dSYM.zip

# Duplicate xcodeproj bundles from Xcode "Save As" collisions
*[[:space:]][0-9].xcodeproj/

# ── Oracle (Python) ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.venv/
venv/
# Live decree state / runtime logs — regenerated by the daily job
oracle/*.db
oracle/*.log
oracle/wordle-broker/*.log
oracle/decrees.json
oracle/chronicle-*/
# (Bundled app fallbacks ios/Resources/decrees.json & macos/... ARE committed.)

# (App Store screenshots under ios/docs/appstore-screenshots* ARE committed
#  so both collaborators have them; re-render via the ShotHarness when they change.)

# ── macOS cruft ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
